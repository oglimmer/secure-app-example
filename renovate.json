{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":enableVulnerabilityAlerts",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "timezone": "Europe/Berlin",
  "schedule": ["before 5am on monday"],
  "prHourlyLimit": 1,
  "prConcurrentLimit": 3,
  "rebaseWhen": "behind-base-branch",
  "rangeStrategy": "bump",
  "automergeType": "branch",
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "packageRules": [
    { "automerge": true, "matchUpdateTypes": ["minor", "patch"] },
    { "matchCurrentVersion": "/^0\\./", "automerge": false },
    { "matchManagers": ["npm"], "groupName": "npm dependencies" },
    { "matchManagers": ["maven"], "groupName": "Maven dependencies" },
    { "matchManagers": ["dockerfile", "docker-compose"], "groupName": "Docker dependencies" }
  ]
}
